    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch brotli-benchmark (debug)",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "Build brotli-benchmark",
            "program": "${workspaceFolder}/ncd/target/debug/benchmark",
            "args": ["wiki-vs-grok", "../../dataset/grokvswiki/dataset.csv"],
            "cwd": "${workspaceFolder}/ncd/brotli-benchmark",
            "env": {
                "RUST_BACKTRACE": "1"
            },
            "stopOnEntry": false
        }
    ]
}
